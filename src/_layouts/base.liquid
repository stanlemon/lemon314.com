<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  {% if description %}<meta property="og:description" content="{{ description }}">{% endif %}
  <meta property="og:image" content="{{ site.url }}/images/graphics/banner.gif">

  <link rel="stylesheet" href="/styles.css">

  <!-- Person schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Robert Lemon",
    "url": "{{ site.url }}",
    "description": "Retired mathematics teacher with 27 years at Community High School District 94, computer instructor at College of DuPage, and community servant in West Chicago, Illinois.",
    "alumniOf": {
      "@type": "CollegeOrUniversity",
      "name": "Northern Michigan University"
    },
    "hasOccupation": {
      "@type": "Occupation",
      "name": "Mathematics Teacher"
    },
    "knowsAbout": ["Mathematics", "Education", "Community Service", "Local Government"],
    "homeLocation": {
      "@type": "Place",
      "name": "West Chicago, Illinois"
    },
    "jobTitle": "Retired Mathematics Teacher"
  }
  </script>
  {% if schemaType == "NewsArticle" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": "{{ title }}",
    "url": "{{ site.url }}{{ page.url }}"{% if articleDate %},
    "datePublished": "{{ articleDate }}"{% endif %},
    "about": {
      "@type": "Person",
      "name": "Robert Lemon",
      "url": "{{ site.url }}"
    }
  }
  </script>
  {% endif %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
{{ content }}
</body>
</html>
